<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.HRMS" parent="Theme.MaterialComponents.DayNight.DarkActionBar.Bridge">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#FAF6F6</item>
        <item name="android:textColorPrimary">#000000</item>
        <item name="colorPrimaryVariant">#FAF6F6</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">#303262</item>
        <item name="drawerArrowStyle">@style/drawerArrowStyle</item>
        <!--         for searchview hint color of searchview-->
        <item name="android:textColorHint">#404040</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
        <!-- Customize your theme here. -->

        <item name="materialCalendarTheme">@style/CustomDatePickerTheme</item>

    </style>

    <!--    change background color of alert dialog-->
    <style name="MaterialAlertDialog_OK_color" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <!-- Style for positive button -->
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle.textColor</item>
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle.textColor</item>
        <item name="android:background">@color/white</item>
        <item name="android:colorAccent">#000000</item>
        <item name="android:textColorPrimary">#000000</item>
        <item name="drawerArrowStyle">@style/drawerArrowStyle</item>

    </style>


    <style name="PositiveButtonStyle.textColor" parent="@style/Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="NegativeButtonStyle.textColor" parent="@style/Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextAppearance.AppCompat.Widget.ActionBar.Title" parent="@android:style/TextAppearance">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">22dp</item>
    </style>

    <style name="drawerArrowStyle" parent="@style/Widget.AppCompat.DrawerArrowToggle">
        <item name="spinBars">true</item>
        <item name="color">#000000</item>
    </style>

    <style name="chipText" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/gilroy_thin</item>
        <item name="chipBackgroundColor">@color/chip_colors</item>
        <item name="android:textColor">@color/chip_text_colors</item>
        <item name="checkedIconTint">@color/black</item>
        <item name="checkedIconVisible">true</item>
    </style>

    <style name="Theme.ImagePicker.NoEdgeToEdge" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- Make sure status bar has a solid background, not transparent -->
        <item name="android:statusBarColor">@android:color/white</item>
        <!-- Set icons/text dark on light background -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- Important: respect system insets -->
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="CustomDatePickerTheme" parent="ThemeOverlay.MaterialComponents.MaterialCalendar.Fullscreen">
        <!-- Header background -->
        <item name="colorPrimary">#303262</item>

        <!-- Header text color -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Calendar background -->
        <item name="colorSurface">@color/white</item>

        <!-- Calendar text (dates) -->
        <item name="colorOnSurface">@color/black</item>

        <!-- Selected date highlight -->
        <item name="colorSecondary">@color/teal_700</item>

        <!-- Range highlight color -->
        <item name="colorSecondaryContainer">@color/teal_200</item>

        <!-- Navigation arrows and text color -->
        <item name="colorOnBackground">@color/black</item>
    </style>

</resources>
