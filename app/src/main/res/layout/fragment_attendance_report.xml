<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <Button
            android:id="@+id/button24"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/attendance_button"
            android:text="From :"
            android:visibility="visible"
            app:cornerRadius="25dp"
            app:layout_constraintEnd_toStartOf="@+id/button25"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/button25"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/attendance_button"
            android:text="To:"
            android:visibility="visible"
            app:cornerRadius="25dp"
            app:layout_constraintEnd_toStartOf="@+id/button26"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/button24"
            app:layout_constraintTop_toTopOf="@+id/button24" />

        <Button
            android:id="@+id/button26"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/attendance_button"
            android:text="Apply"
            android:visibility="visible"
            app:cornerRadius="25dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/button25"
            app:layout_constraintTop_toTopOf="@+id/button25" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/attendance_report_list"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView310"
            app:layout_constraintVertical_bias="0.5" />

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/not_available1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/attendance_report_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/attendance_report_list"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/not_available" />

        <TextView
            android:id="@+id/textView310"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginTop="8dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Date"
            android:textColor="#000000"
            app:layout_constraintEnd_toStartOf="@+id/textView311"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button24" />

        <TextView
            android:id="@+id/textView312"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Present"
            android:textColor="#000000"
            app:layout_constraintEnd_toStartOf="@+id/textView323"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/textView311"
            app:layout_constraintTop_toTopOf="@+id/textView311" />

        <TextView
            android:id="@+id/textView323"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Absent"
            android:textColor="#000000"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/textView312"
            app:layout_constraintTop_toTopOf="@+id/textView311" />

        <TextView
            android:id="@+id/textView311"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Expected"
            android:textColor="#000000"
            app:layout_constraintEnd_toStartOf="@+id/textView312"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/textView310"
            app:layout_constraintTop_toTopOf="@+id/textView310" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/download_report"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            app:backgroundTint="#303262"
            app:fabCustomSize="65dp"
            app:layout_constraintBottom_toBottomOf="@+id/attendance_report_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:maxImageSize="40dp"
            app:srcCompat="@drawable/ic_baseline_file_download_24"
            app:tint="#FFFFFF" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/attendance_report_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/attendance_report_list" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>