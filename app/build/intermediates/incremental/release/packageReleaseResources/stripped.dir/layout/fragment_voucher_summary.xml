<?xml version="1.0" encoding="utf-8"?>

                                                  
                                                        

    

           

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF" android:tag="layout/fragment_voucher_summary_0" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools" xmlns:app="http://schemas.android.com/apk/res-auto">

        <Button
            android:id="@+id/button24"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/attendance_button"
            android:text="From :"
            android:visibility="visible"
            app:cornerRadius="25dp"
            app:layout_constraintEnd_toStartOf="@+id/button25"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tl1" />

        <Button
            android:id="@+id/button25"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/attendance_button"
            android:text="To:"
            android:visibility="visible"
            app:cornerRadius="25dp"
            app:layout_constraintEnd_toStartOf="@+id/button26"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/button24"
            app:layout_constraintTop_toTopOf="@+id/button24" />

        <Button
            android:id="@+id/button26"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/attendance_button"
            android:text="Apply"
            android:visibility="visible"
            app:cornerRadius="25dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/button25"
            app:layout_constraintTop_toTopOf="@+id/button25" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/attendance_report_list"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView310" />

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/not_available1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/attendance_report_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/attendance_report_list"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/not_available" />

        <TextView
            android:id="@+id/textView310"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginTop="8dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Date"
            android:textColor="#000000"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/textView311"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button24" />

        <TextView
            android:id="@+id/textView312"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Pending"
            android:textColor="#000000"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/textView323"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/textView311"
            app:layout_constraintTop_toTopOf="@+id/textView311" />

        <TextView
            android:id="@+id/textView323"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Rejected"
            android:textColor="#000000"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/textView398"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/textView312"
            app:layout_constraintTop_toTopOf="@+id/textView311" />

        <TextView
            android:id="@+id/textView398"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Approved"
            android:textColor="#000000"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/textView467"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/textView323"
            app:layout_constraintTop_toTopOf="@+id/textView323" />

        <TextView
            android:id="@+id/textView467"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Paid"
            android:textColor="#000000"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/textView398"
            app:layout_constraintTop_toTopOf="@+id/textView398" />

        <TextView
            android:id="@+id/textView311"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:background="#C1C1C1"
            android:fontFamily="@font/gilroy_bold"
            android:gravity="center"
            android:text="Total"
            android:textColor="#000000"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/textView312"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/textView310"
            app:layout_constraintTop_toTopOf="@+id/textView310" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/download_report"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="visible"
            app:backgroundTint="#303262"
            app:fabCustomSize="65dp"
            app:layout_constraintBottom_toBottomOf="@+id/attendance_report_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:maxImageSize="40dp"
            app:srcCompat="@drawable/ic_baseline_file_download_24"
            app:tint="#FFFFFF" />


        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/attendance_report_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/attendance_report_list" />


        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tl1"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="2dp"
            android:hint="Select Client"
            android:textColorHint="#969494"
            android:visibility="gone"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:endIconTint="#626060"
            app:layout_constraintEnd_toStartOf="@+id/tl2"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <AutoCompleteTextView
                android:id="@+id/company"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/edit_text_back"
                android:freezesText="true"
                android:paddingLeft="18dp"
                android:popupBackground="@color/white"
                android:textColor="#000000"
                android:textColorHint="#969494" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/textView204"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="-4dp"
            android:fontFamily="@font/gilroy_medium"
            android:text="Select Client"
            android:textColor="#FF0000"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/tl1"
            app:layout_constraintStart_toStartOf="@+id/tl1" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tl2"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:hint="Select Site"
            android:textColorHint="#969494"
            android:visibility="gone"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:endIconTint="#626060"
            app:layout_constraintEnd_toStartOf="@+id/tl3"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/tl1"
            app:layout_constraintTop_toTopOf="@+id/tl1">

            <AutoCompleteTextView
                android:id="@+id/branch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/edit_text_back"
                android:freezesText="true"
                android:paddingLeft="18dp"
                android:popupBackground="@color/white"
                android:textColor="#000000"
                android:textColorHint="#969494" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tl3"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="4dp"
            android:hint="Select Gang"
            android:textColorHint="#969494"
            android:visibility="gone"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:endIconTint="#626060"
            app:layout_constraintEnd_toStartOf="@+id/addLeave2"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/tl2"
            app:layout_constraintTop_toTopOf="@+id/tl1">

            <AutoCompleteTextView
                android:id="@+id/gang"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/edit_text_back"
                android:freezesText="true"
                android:paddingLeft="18dp"
                android:popupBackground="@color/white"
                android:textColor="#000000"
                android:textColorHint="#969494" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/textView205"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="-4dp"
            android:fontFamily="@font/gilroy_medium"
            android:text="Select Site"
            android:textColor="#FF0000"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/tl2"
            app:layout_constraintStart_toStartOf="@+id/tl2" />

        <TextView
            android:id="@+id/textView206"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="-4dp"
            android:fontFamily="@font/gilroy_medium"
            android:text="Select Gang"
            android:textColor="#FF0000"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/tl3"
            app:layout_constraintStart_toStartOf="@+id/tl3" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/addLeave2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:backgroundTint="#303262"
            app:fabCustomSize="35dp"
            app:layout_constraintBottom_toBottomOf="@+id/tl2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/tl3"
            app:layout_constraintTop_toTopOf="@+id/tl2"
            app:maxImageSize="18dp"
            app:srcCompat="@drawable/baseline_autorenew_24"
            app:tint="#FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>
         